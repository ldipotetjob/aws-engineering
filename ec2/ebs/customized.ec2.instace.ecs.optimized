<<<<<System cleanup (claude ai)>>>>>>>>

# Stop ECS agent
sudo systemctl stop ecs

# Clean ECS state
sudo rm -rf /var/lib/ecs/data/agent.db

# Clear ECS logs
sudo rm -rf /var/log/ecs/*

# Clear temporary files
sudo rm -rf /tmp/*
sudo rm -rf /var/tmp/*

# Clear shell history
history -c
sudo history -c
cat /dev/null > ~/.bash_history
sudo cat /dev/null > /root/.bash_history

# Clear cloud-init state so it reruns on new instances
sudo rm -rf /var/lib/cloud/instances/*
sudo rm -rf /var/lib/cloud/data/*

# Clear SSH host keys (new instances should generate their own)
sudo rm -f /etc/ssh/ssh_host_*

# Sync filesystem to disk
sudo sync

# Verify Docker/ECS still start automatically
