To decompress big files instead of use ONLY tar use the utility pigz:

tar -I pigz -xvf your_file.tar.gz --no-same-owner -C /mnt/sdb/


# ===>> start script for big transfer

screen        # start a resilient session
sudo rsync -a --progress --partial --info=progress2 /mnt/source/ /mnt/target/
# Detach with Ctrl+A then D
screen -r    # reconnect later

# ===>> end script for big transfer

# rsync +++ optimized:

sudo rsync -ahW --inplace --info=progress2 /mnt/source/ /mnt/target/




